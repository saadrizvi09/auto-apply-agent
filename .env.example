# ---- AutoApply configuration template ----
# Copy to .env and fill in. The real .env is git-ignored.

# Safety: when true (default), NOTHING is actually sent and no paid/quota API is
# called for real — integrations log what they WOULD do. Flip to false only when
# you are ready for real sends, and the first real send must target a secondary
# inbox you control.
DRY_RUN=true

# API keys
GROQ_API_KEY=
GROQ_API_KEY_BACKUP=          # optional: 2nd Groq key, used automatically on a 429 rate-limit
HUNTER_API_KEY_BACKUP=        # optional: 2nd Hunter account key, used when the 1st's 50/mo runs out
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
HUNTER_API_KEY=

# Behavior (overridable in the settings table via the UI)
CV_PATH=./cv.pdf
# Short candidate summary passed to the draft prompt (NOT the full PDF).
CV_SUMMARY=Final-year CS student; DSA + full-stack (React/Node); 2 internships; projects X/Y
# Date the SENDER Gmail account was created (YYYY-MM-DD). Used by the warm-up gate.
# Leave blank to keep sending gated until you confirm the account is aged.
ACCOUNT_CREATED_DATE=
SENDER_NAME=Your Name
SIGNATURE=Your Name | +91-XXXXXXXXXX | github.com/you | linkedin.com/in/you
DAILY_CAP=20                 # ramp target (Day6+); absolute ceiling 75
WARMUP_RAMP=true             # false = full DAILY_CAP from day 1 (skips the warm-up ramp)
LI_DAILY_CAP=30              # autonomous LinkedIn auto-applies per day (ban risk rises with this)
LI_WARMUP_RAMP=true          # ramp LinkedIn applies: Day1-2=8, Day3-5=15, Day6+=LI_DAILY_CAP
SEND_DELAY_MIN=90            # seconds
SEND_DELAY_MAX=180
BOUNCE_PAUSE_THRESHOLD=0.03  # 3%
MIN_ACCOUNT_AGE_DAYS=14      # warm-up gate
DUP_WINDOW_DAYS=5
SCAN_INTERVAL_MINUTES=60
GMAIL_LABEL=AutoApply
REQUIRE_VERIFIED=true        # block sends to unverified unless operator overrides

# First real send guard: until this matches the recipient, real sending is refused.
# Leave blank during development.
FIRST_SEND_TEST_INBOX=
